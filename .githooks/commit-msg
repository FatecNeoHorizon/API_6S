#!/bin/bash

# Git Hook: Valida mensagens de commit
# Padrão: Conventional Commits
# 
# Formatos aceitos:
#   feat(escopo): descrição
#   fix(escopo): descrição
#   docs: descrição
#   style: descrição
#   refactor(escopo): descrição
#   perf(escopo): descrição
#   test: descrição
#   chore: descrição
#   ci: descrição
#   revert: descrição

COMMIT_MSG=$(cat "$1")
TIPO_PATTERN="^(feat|fix|docs|style|refactor|perf|test|chore|ci|revert)(\(.+\))?!?:"

# Ignora mensagens que começam com # (comentários do merge, rebase, etc)
if echo "$COMMIT_MSG" | grep -q "^#"; then
  exit 0
fi

# Valida o padrão
if ! echo "$COMMIT_MSG" | grep -qE "$TIPO_PATTERN"; then
  echo ""
  echo "╔════════════════════════════════════════════════════════════════╗"
  echo "║          ❌ ERRO: Commit inválido!                            ║"
  echo "╚════════════════════════════════════════════════════════════════╝"
  echo ""
  echo "Sua mensagem: \"$COMMIT_MSG\""
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "📋 Convenção: Conventional Commits"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  echo "✅ Formatos VÁLIDOS:"
  echo ""
  echo "  🎯 Nova Funcionalidade:"
  echo "     feat(auth): implementar login com JWT"
  echo "     feat(users): adicionar validação de email"
  echo ""
  echo "  🐛 Correção de Bug:"
  echo "     fix(api): corrigir erro de autenticação"
  echo "     fix(db): ajustar query de performance"
  echo ""
  echo "  📚 Documentação:"
  echo "     docs: atualizar README"
  echo "     docs: adicionar guia de contribuição"
  echo ""
  echo "  🎨 Estilo (sem lógica):"
  echo "     style: corrigir indentação"
  echo "     style: reformatar código"
  echo ""
  echo "  ♻️  Refatoração:"
  echo "     refactor(auth): reorganizar código de autenticação"
  echo "     refactor: melhorar estrutura de pastas"
  echo ""
  echo "  ⚡ Performance:"
  echo "     perf(api): otimizar busca de usuários"
  echo "     perf: reduzir tamanho do bundle"
  echo ""
  echo "  🧪 Testes:"
  echo "     test: adicionar testes unitários"
  echo "     test(auth): aumentar cobertura de autenticação"
  echo ""
  echo "  🔧 Mudanças na Build/Config:"
  echo "     chore: atualizar dependências"
  echo "     chore: configurar linter"
  echo ""
  echo "  🔄 Integração Contínua:"
  echo "     ci: atualizar GitHub Actions"
  echo "     ci: configurar pipeline"
  echo ""
  echo "  ↩️  Reverter Commit:"
  echo "     revert: reverter 'feat(auth): implementar login'"
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "📝 Estrutura:"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  echo "  <tipo>(<escopo>): <descrição>"
  echo "  │      │          │"
  echo "  │      │          └─ Descrição breve em minúsculas"
  echo "  │      └─ Opcional: area/módulo afetado"
  echo "  └─ Obrigatório: feat, fix, docs, style, refactor, perf, test, chore, ci, revert"
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  echo "❌ Commit REJEITADO. Corrija a mensagem e tente novamente:"
  echo ""
  echo "   git commit --amend -m \"<tipo>(<escopo>): <descrição>\""
  echo ""
  exit 1
fi

exit 0
