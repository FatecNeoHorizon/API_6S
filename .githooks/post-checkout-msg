  echo "📋 Convention: Conventional Commits + kebab-case"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  echo "✅ VALID formats:"
  echo ""
  echo "  🎯 New Feature:"
  echo "     feature/add-authentication"
  echo "     feature/implement-jwt-login"
  echo ""
  echo "  🐛 Bug Fix:"
  echo "     bugfix/fix-authentication-error"
  echo "     bugfix/fix-performance-query"
  echo ""
  echo "  🚨 Hotfix (production):"
  echo "     hotfix/fix-api-crash"
  echo "     hotfix/fix-critical-security"
  echo ""
  echo "  📚 Documentation:"
  echo "     docs/update-readme"
