#!/bin/bash

# Git Hook: Valida nomes de branches
# Padrão: Conventional Commits + kebab-case
# 
# Formatos aceitos:
#   feature/descricao-da-feature
#   bugfix/descricao-do-bug
#   docs/descricao-da-documentacao
#   style/descricao-do-estilo
#   refactor/descricao-da-refatoracao
#   perf/descricao-de-performance
#   test/descricao-do-teste
#   chore/descricao-da-tarefa
#   ci/descricao-da-ci
#   revert/descricao-do-revert
#   hotfix/descricao-do-hotfix
#
# EXEMPLO: feature/adicionar-autenticacao-jwt

BRANCH_NAME=$(git rev-parse --abbrev-ref HEAD)
BRANCH_PATTERN="^(feature|bugfix|docs|style|refactor|perf|test|chore|ci|revert|hotfix)\/[a-z0-9]([a-z0-9\-]*[a-z0-9])?$"

# Ignora a branch 'main' e 'develop'
if [[ "$BRANCH_NAME" == "main" ]] || [[ "$BRANCH_NAME" == "develop" ]]; then
  exit 0
fi

# Valida o padrão
if ! [[ "$BRANCH_NAME" =~ $BRANCH_PATTERN ]]; then
  echo ""
  echo "╔════════════════════════════════════════════════════════════════╗"
  echo "║        ⚠️  AVISO: Nome de branch inválido!                     ║"
