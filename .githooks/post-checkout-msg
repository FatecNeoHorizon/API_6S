  echo ""
  echo "  🎨 Style (no logic):"
  echo "     style/fix-indentation"
  echo "     style/reformat-code"
  echo ""
  echo "  ♻️  Refactoring:"
  echo "     refactor/reorganize-authentication"
  echo "     refactor/improve-folder-structure"
  echo ""
  echo "  ⚡ Performance:"
  echo "     perf/optimize-user-search"
