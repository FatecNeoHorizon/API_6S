#!/bin/bash

# Git Hook: Previne push de branches com nomes inválidos
# Padrão: Conventional Commits + kebab-case

BRANCH_NAME=$(git rev-parse --abbrev-ref HEAD)
BRANCH_PATTERN="^(feature|bugfix|docs|style|refactor|perf|test|chore|ci|revert|hotfix|main|develop)\/[a-z0-9]([a-z0-9\-]*[a-z0-9])?$|^(main|develop)$"

# Valida o padrão
if ! [[ "$BRANCH_NAME" =~ $BRANCH_PATTERN ]]; then
  echo ""
  echo "╔════════════════════════════════════════════════════════════════╗"
  echo "║     ❌ ERRO: Não é possível fazer push!                       ║"
  echo "╚════════════════════════════════════════════════════════════════╝"
  echo ""
  echo "Branch: \"$BRANCH_NAME\""
  echo ""
  echo "O nome da branch não segue a convenção estabelecida."
  echo ""
  echo "✅ Formatos aceitos:"
  echo "   feature/descricao"
  echo "   bugfix/descricao"
  echo "   hotfix/descricao"
  echo "   docs/descricao"
  echo "   style/descricao"
  echo "   refactor/descricao"
  echo "   perf/descricao"
  echo "   test/descricao"
  echo "   chore/descricao"
  echo "   ci/descricao"
  echo "   revert/descricao"
  echo ""
  echo "💡 Solução: Renomear a branch:"
  echo ""
  echo "   git branch -m feature/nome-valido"
  echo "   git push -u origin feature/nome-valido"
  echo ""
  exit 1
fi

exit 0
