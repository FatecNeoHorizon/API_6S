#!/bin/bash

# Git Hook: Prevents push of branches with invalid names
# Standard: Conventional Commits + kebab-case

BRANCH_NAME=$(git rev-parse --abbrev-ref HEAD)
BRANCH_PATTERN="^(feature|bugfix|docs|style|refactor|perf|test|chore|ci|revert|hotfix|main|develop)\/[a-z0-9]([a-z0-9\-]*[a-z0-9])?$|^(main|develop)$"

# Validate branch name pattern
if ! [[ "$BRANCH_NAME" =~ $BRANCH_PATTERN ]]; then
  echo ""
  echo "╔════════════════════════════════════════════════════════════════╗"
  echo "║     ❌ ERROR: Push not allowed!                               ║"
  echo "╚════════════════════════════════════════════════════════════════╝"
  echo ""
  echo "Branch: \"$BRANCH_NAME\""
  echo ""
  echo "The branch name does not follow the established convention."
  echo ""
  echo "✅ Accepted formats:"
  echo "   feature/description"
  echo "   bugfix/description"
  echo "   hotfix/description"
  echo "   docs/description"
  echo "   style/description"
  echo "   refactor/description"
  echo "   perf/description"
  echo "   test/description"
  echo "   chore/description"
  echo "   ci/description"
  echo "   revert/description"
  echo ""
  echo "💡 Solution: Rename the branch:"
  echo ""
  echo "   git branch -m feature/valid-name"
  echo "   git push -u origin feature/valid-name"
  echo ""
  exit 1
fi

exit 0