# Application Configuration
APP_ENV=dev
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
TMP_UPLOAD_PATH=/app/tmp

# Fernet key for reversible e-mail encryption at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
EMAIL_ENCRYPTION_KEY=

# TECH_DEBT(5.3): email hash is provisional SHA-256 without salt.
# Reserved for future salted hashing migration.
EMAIL_HASH_SALT=

# MongoDB Connection Settings
MONGO_HOST=
MONGO_PORT=
MONGO_USER=
MONGO_PASSWORD=
MONGO_DB_NAME=

# MongoDB Connection Pool Settings (timeouts in milliseconds)
MONGO_MAX_POOL_SIZE=
MONGO_SERVER_SELECTION_TIMEOUT_MS=
MONGO_CONNECT_TIMEOUT_MS=
MONGO_MAX_POOL_SIZE=10
MONGO_SERVER_SELECTION_TIMEOUT_MS=120000
MONGO_CONNECT_TIMEOUT_MS=10000

#Postgres Connection
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Model retraining policy
# When true, the backend will schedule model retraining after data loads.
MODEL_RETRAIN_ON_NEW_DATA=false
# Strategy can be 'per_load' (default) or extended later.
MODEL_RETRAIN_STRATEGY=per_load
# Minimum new records required for retraining per consumer unit + indicator
MODEL_RETRAIN_MIN_NEW_RECORDS=1