  echo "  │       │"
  echo "  │       └─ Lowercase description with hyphens"
  echo "  └─ Required: feature, bugfix, hotfix, docs, style, refactor, perf, test, chore, ci, revert"
  echo ""
  echo "  ✅ CORRECT:   feature/add-login"
