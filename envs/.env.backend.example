# Application Configuration
APP_ENV=dev
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
CSV_FILE_PATH=./data/

# MongoDB Connection Settings
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_USER=admin
MONGO_PASSWORD=password
MONGO_DB_NAME=tecsys

# MongoDB Connection Pool Settings (timeouts in milliseconds)
MONGO_MAX_POOL_SIZE=10
MONGO_SERVER_SELECTION_TIMEOUT_MS=120000
MONGO_CONNECT_TIMEOUT_MS=10000

# Alternative MongoDB Docker Compose Credentials (optional, if MONGO_USER/PASSWORD not set)
# MONGO_INITDB_ROOT_USERNAME=admin
# MONGO_INITDB_ROOT_PASSWORD=password
