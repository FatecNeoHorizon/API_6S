#!/bin/bash

# Git Hook: Validates commit messages
# Standard: Conventional Commits
#
# Accepted formats:
#   feat(scope): description
#   fix(scope): description
#   docs: description
#   style: description
#   refactor(scope): description
#   perf(scope): description
#   test: description
#   chore: description
#   ci: description
#   revert: description
#
# Footer (REQUIRED):
#   #123
#   Closes #123
#   Ref: #123

COMMIT_MSG=$(cat "$1")
TYPE_PATTERN="^(feat|fix|docs|style|refactor|perf|test|chore|ci|revert)(\(.+\))?!?:"
ISSUE_PATTERN="(Closes|Ref:)?\s*#[0-9]+"

# Ignore messages starting with # (merge, rebase comments, etc.)
if echo "$COMMIT_MSG" | grep -q "^#"; then
  exit 0
fi

# Validate commit type pattern
if ! echo "$COMMIT_MSG" | grep -qE "$TYPE_PATTERN"; then
  echo ""
  echo "╔════════════════════════════════════════════════════════════════╗"
  echo "║          ❌ ERROR: Invalid commit!                            ║"
  echo "╚════════════════════════════════════════════════════════════════╝"
  echo ""
  echo "Your message: \"$COMMIT_MSG\""
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "📋 Convention: Conventional Commits"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  echo "✅ VALID formats:"
  echo ""
  echo "  🎯 New Feature:"
  echo "     feat(auth): implement JWT login"
  echo "     feat(users): add email validation"
  echo ""
  echo "  🐛 Bug Fix:"
  echo "     fix(api): fix authentication error"
  echo "     fix(db): adjust performance query"
  echo ""
  echo "  📚 Documentation:"
  echo "     docs: update README"
  echo "     docs: add contributing guide"
  echo ""
  echo "  🎨 Style (no logic):"
  echo "     style: fix indentation"
  echo "     style: reformat code"
  echo ""
  echo "  ♻️  Refactoring:"
  echo "     refactor(auth): reorganize authentication code"
  echo "     refactor: improve folder structure"
  echo ""
  echo "  ⚡ Performance:"
  echo "     perf(api): optimize user search"
  echo "     perf: reduce bundle size"
  echo ""
  echo "  🧪 Tests:"
  echo "     test: add unit tests"
  echo "     test(auth): increase authentication coverage"
  echo ""
  echo "  🔧 Build/Config Changes:"
  echo "     chore: update dependencies"
  echo "     chore: configure linter"
  echo ""
  echo "  🔄 Continuous Integration:"
  echo "     ci: update GitHub Actions"
  echo "     ci: configure pipeline"
  echo ""
  echo "  ↩️  Revert Commit:"
  echo "     revert: revert 'feat(auth): implement login'"
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "📝 Structure:"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  echo "  <type>(<scope>): <description>"
  echo "  │      │          │"
  echo "  │      │          └─ Short description in lowercase"
  echo "  │      └─ Optional: affected area/module"
  echo "  └─ Required: feat, fix, docs, style, refactor, perf, test, chore, ci, revert"
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  echo "❌ Commit REJECTED. Fix your message and try again:"
  echo ""
  echo "   git commit --amend -m \"<type>(<scope>): <description>"
  echo ""
  echo "   #<issue-number>\""
  echo ""
  exit 1
fi

# Validate footer issue reference (REQUIRED)
if ! echo "$COMMIT_MSG" | grep -qE "$ISSUE_PATTERN"; then
  echo ""
  echo "╔════════════════════════════════════════════════════════════════╗"
  echo "║          ❌ ERROR: Missing issue reference!                   ║"
  echo "╚════════════════════════════════════════════════════════════════╝"
  echo ""
  echo "Your message: \"$COMMIT_MSG\""
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "📋 Every commit MUST reference an issue in the footer."
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  echo "✅ Accepted formats:"
  echo ""
  echo "  #123                 (shorthand reference)"
  echo "  Ref: #123            (reference without closing)"
  echo "  Closes #123          (closes the issue automatically on merge)"
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "📝 Full example:"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  echo "  feat(auth): implement JWT login"
  echo ""
  echo "  Add stateless authentication with JWT."
  echo ""
  echo "  Ref: #42"
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  echo "❌ Commit REJECTED. Fix your message and try again:"
  echo ""
  echo "   git commit --amend -m \"<type>(<scope>): <description>"
  echo ""
  echo "   #<issue-number>\""
  echo ""
  exit 1
fi

exit 0