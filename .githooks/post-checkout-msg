#!/bin/bash

# Git Hook: Validates branch names
# Standard: Conventional Commits + kebab-case
#
# Accepted formats:
#   feature/feature-description
#   bugfix/bug-description
#   docs/documentation-description
#   style/style-description
#   refactor/refactor-description
#   perf/performance-description
#   test/test-description
#   chore/chore-description
#   ci/ci-description
#   revert/revert-description
#   hotfix/hotfix-description
#
# EXAMPLE: feature/add-jwt-authentication

BRANCH_NAME=$(git rev-parse --abbrev-ref HEAD)
BRANCH_PATTERN="^(feature|bugfix|docs|style|refactor|perf|test|chore|ci|revert|hotfix)\/[a-z0-9]([a-z0-9\-]*[a-z0-9])?$"

# Ignore 'main' and 'develop' branches
if [[ "$BRANCH_NAME" == "main" ]] || [[ "$BRANCH_NAME" == "develop" ]]; then
  exit 0
fi

# Ignore commits from bots/automation
AUTHOR=$(git log --format="%ae" -n 1 HEAD)
if echo "$AUTHOR" | grep -qE "(github-actions|bot)\[bot\]|noreply\.github\.com"; then
  exit 0
fi

# Validate branch name pattern
if ! [[ "$BRANCH_NAME" =~ $BRANCH_PATTERN ]]; then
  echo ""
  echo "╔════════════════════════════════════════════════════════════════╗"
  echo "║        ⚠️  WARNING: Invalid branch name!                       ║"
  echo "╚════════════════════════════════════════════════════════════════╝"
  echo ""
  echo "Your branch: \"$BRANCH_NAME\""
  echo ""
