# Application Configuration
APP_ENV=dev
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
CSV_FILE_PATH=/app/data/indicadores-continuidade-coletivos-2020-2029.csv

# MongoDB Connection Settings
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_USER=admin
MONGO_PASSWORD=password
MONGO_DB_NAME=tecsys

# MongoDB Connection Pool Settings (timeouts in milliseconds)
MONGO_MAX_POOL_SIZE=10
MONGO_SERVER_SELECTION_TIMEOUT_MS=120000
MONGO_CONNECT_TIMEOUT_MS=10000

# Chave para criptografia de e-mails com Fernet.
# Para gerar uma nova chave, execute: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
EMAIL_ENCRYPTION_KEY=

# Salt para hashing de e-mails.
# Para gerar um novo salt, execute: python -c "import secrets; print(secrets.token_hex(32))"
EMAIL_HASH_SALT=
