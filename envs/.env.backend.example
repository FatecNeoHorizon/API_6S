# Application Configuration
APP_ENV=
BACKEND_URL=
FRONTEND_URL=

# Fixed salt used for deterministic SHA-256 email hashing
EMAIL_HASH_SALT=

# Optional Fernet key (urlsafe base64, 32-byte key) for EMAIL_ENC encryption.
# If empty, backend derives a deterministic dev key from EMAIL_HASH_SALT.
EMAIL_ENCRYPTION_KEY=

# MongoDB Connection Settings
MONGO_HOST=
MONGO_PORT=
MONGO_USER=
MONGO_PASSWORD=
MONGO_DB_NAME=

# MongoDB Connection Pool Settings (timeouts in milliseconds)
MONGO_MAX_POOL_SIZE=
MONGO_SERVER_SELECTION_TIMEOUT_MS=
MONGO_CONNECT_TIMEOUT_MS=

TMP_UPLOAD_PATH=
